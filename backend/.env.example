# Banco de dados (obrigatório quando rodar o backend fora do Docker)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=iot_user
MYSQL_PASSWORD=sua_senha
MYSQL_DB=iot_data

# Broker MQTT (o backend usa isso para conectar)
MQTT_BROKER_URL=mqtt://localhost:1883

# Opcional: endereço do broker que vai no código gerado pelo wizard.
# Use quando os dispositivos (ESP, etc.) estiverem em outra rede:
# defina o IP ou hostname do servidor onde o broker está (ex: 192.168.1.100).
# Se não definir, o código usará o host/porta extraídos de MQTT_BROKER_URL.
# MQTT_PUBLIC_HOST=192.168.1.100
# MQTT_PUBLIC_PORT=1883
